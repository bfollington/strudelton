# Copy to .env and set for your machine. Read by @ableton-extensions/cli (`npm start`)
# to launch Live's Extension Host. Requires Live 12.4.5+ Suite Beta with Developer Mode
# enabled (Preferences → Extensions → Developer Mode).
#
# Point at the Extension Host module inside the Live beta app. On macOS it is inside the
# .app bundle; you can also pass the .app path to the CLI via `--live` instead.
EXTENSION_HOST_PATH=/Applications/Ableton Live 12.4 Beta.app
