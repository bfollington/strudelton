{
  "name": "strudelton-extension",
  "version": "0.1.0",
  "description": "Strudel -> MIDI clip bake, as an Ableton Live extension (probe).",
  "main": "dist/extension.js",
  "engines": {
    "node": ">=22.11.0"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "npm run build:dev && extensions-cli run",
    "package": "npm run build && extensions-cli package",
    "smoke": "tsx build.ts && node dist/bundle-smoke.cjs"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:../vendor/sdk/ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:../vendor/sdk/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^24.1.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
